# === Refund Agent — environment template ===
# Copy to backend/.env and fill in your key:  cp backend/.env.example backend/.env
#
# Required: your Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Optional (defaults shown). The /admin Settings page overrides model / effort /
# --- guardrails / identity at runtime, so you usually don't need to set these here.
# DB_PATH=./data/app.db
# DEFAULT_MODEL=claude-sonnet-4-6
# DEFAULT_EFFORT=medium
# ADAPTIVE_THINKING=false
# MAX_OUTPUT_TOKENS=4096
# IDENTITY_MODE=authenticated
# INPUT_GUARD_ENABLED=true
# OUTPUT_VALIDATION_ENABLED=true
# ALLOWED_ORIGINS=["*"]
